{
    "interface_version": 2,
    "name": "MaaLK",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    "github": "https://github.com/krendluck/lkwg",
    "version": "0.1.0",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "洛克王国：世界",
                "screencap": "FramePool",
                "mouse": "Seize",
                "keyboard": "Seize"
            }
        }
    ],
    "resource": [
        {
            "name": "桌面",
            "path": [
                "resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "./agent/main.py"
        ]
    },
    "task": [
        {
            "name": "自动登录",
            "entry": "Auto_LaunchEntry"
        },
        {
            "name": "自动聚能",
            "entry": "Focus_EnergyEntry",
            "option": [
                "聚能方式"
            ]
        },
        {
            "name": "战斗脱离",
            "entry": "Battle_RunEntry",
            "option": [
                "战斗脱离",
                "脱离方式"
            ]
        },
        {
            "name": "自动放宠",
            "entry": "AutoReleasePet_Entry",
            "option": [
                "放宠设置"
            ]
        },
        {
            "name": "鼠标长按",
            "entry": "MouseLongPressEntry",
            "option": [
                "映射按键"
            ]
        }
    ],
    "option": {
        "聚能方式": {
            "type": "select",
            "default_case": "点击方式",
            "cases": [
                {
                    "name": "按键 x",
                    "label": "按键 x",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "ClickKey",
                            "key": 88
                        }
                    }
                },
                {
                    "name": "点击方式",
                    "label": "点击方式",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "Click",
                            "target": true
                        }
                    }
                }
            ]
        },
        "战斗脱离": {
            "type": "select",
            "default_case": "只脱离一次",
            "cases": [
                {
                    "name": "只脱离一次",
                    "label": "只脱离一次",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": []
                        }
                    }
                },
                {
                    "name": "后台持续检测",
                    "label": "后台持续检测",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": [
                                "Battle_RunEntry"
                            ]
                        }
                    }
                }
            ]
        },
        "脱离方式": {
            "type": "select",
            "default_case": "点击脱离",
            "cases": [
                {
                    "name": "点击脱离",
                    "label": "点击脱离",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "Click",
                            "target": true
                        }
                    }
                },
                {
                    "name": "按键 ESC",
                    "label": "按键 ESC",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "ClickKey",
                            "key": 27
                        }
                    }
                }
            ]
        },
        "放宠设置": {
            "type": "input",
            "label": "放宠参数",
            "inputs": [
                {
                    "name": "threshold",
                    "label": "匹配阈值(0-10)",
                    "default": "7",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入0-10的整数"
                },
                {
                    "name": "window",
                    "label": "确认窗口(帧数)",
                    "default": "10",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入正整数"
                },
                {
                    "name": "ratio",
                    "label": "确认比例(0-10)",
                    "default": "7",
                    "pipeline_type": "int",
                    "verify": "^\\d+$",
                    "pattern_msg": "请输入0-10的整数"
                }
            ],
            "pipeline_override": {
                "AutoReleasePet_Entry": {
                    "custom_recognition_param": "{\"slots\":[[49,129,69,37],[49,185,69,33],[49,239,69,35],[49,294,69,33],[49,349,69,34]],\"match_threshold\":「threshold」,\"confirm_window\":「window」,\"confirm_ratio\":「ratio」,\"debug_log\":true}"
                }
            }
        },
        "映射按键": {
            "type": "input",
            "label": "鼠标长按设置",
            "inputs": [
                {
                    "name": "key",
                    "label": "映射按键(字母/数字/空格)",
                    "default": "c",
                    "pipeline_type": "string",
                    "verify": "^[0-9a-zA-Z ]$",
                    "pattern_msg": "请输入一个按键(字母、数字或空格)"
                }
            ],
            "pipeline_override": {
                "MouseLongPressEntry": {
                    "custom_action_param": "{\"key\":\"「key」\"}"
                }
            }
        }
    }    
}