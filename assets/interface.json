{
    "interface_version": 2,
    "name": "MaaLK",
    "description": "这是一个使用 MaaFramework 创建的新项目。",
    "license": "MIT",
    "welcome": "首次使用！欢迎使用 MAA!",
    "github": "https://github.com/krendluck/lkwg",
    "version": "0.1.0",
    "controller": [
        {
            "name": "桌面端",
            "type": "Win32",
            "win32": {
                "class_regex": ".*",
                "window_regex": "洛克王国：世界",
                "screencap": "FramePool",
                "mouse": "Seize",
                "keyboard": "Seize"
            }
        }
    ],
    "resource": [
        {
            "name": "桌面",
            "path": [
                "resource"
            ]
        }
    ],
    "agent": {
        "child_exec": "python",
        "child_args": [
            "../agent/main.py"
        ]
    },
    "task": [
        {
            "name": "自动登录",
            "entry": "Auto_LaunchEntry"
        },
        {
            "name": "自动聚能",
            "entry": "Focus_EnergyEntry",
            "option": [
                "聚能方式"
            ]
        },
        {
            "name": "战斗脱离",
            "entry": "Battle_RunEntry",
            "option": [
                "战斗脱离",
                "脱离方式"
            ]
        },
        {
            "name": "自动放宠",
            "entry": "AutoReleasePet_Entry",
            "option": [
                "轮询间隔"
            ]
        },
        {
            "name": "鼠标长按",
            "entry": "MouseLongPressEntry",
            "option": [
                "映射按键"
            ]
        }
    ],
    "option": {
        "聚能方式": {
            "type": "select",
            "default_case": "点击方式",
            "cases": [
                {
                    "name": "按键 x",
                    "label": "按键 x",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "ClickKey",
                            "key": 88
                        }
                    }
                },
                {
                    "name": "点击方式",
                    "label": "点击方式",
                    "pipeline_override": {
                        "Focus_EnergyEntry": {
                            "action": "Click",
                            "target": true
                        }
                    }
                }
            ]
        },
        "战斗脱离": {
            "type": "select",
            "default_case": "只脱离一次",
            "cases": [
                {
                    "name": "只脱离一次",
                    "label": "只脱离一次",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": []
                        }
                    }
                },
                {
                    "name": "后台持续检测",
                    "label": "后台持续检测",
                    "pipeline_override": {
                        "Confirm_Yes": {
                            "next": [
                                "Battle_RunEntry"
                            ]
                        }
                    }
                }
            ]
        },
        "脱离方式": {
            "type": "select",
            "default_case": "点击脱离",
            "cases": [
                {
                    "name": "点击脱离",
                    "label": "点击脱离",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "Click",
                            "target": true
                        }
                    }
                },
                {
                    "name": "按键 ESC",
                    "label": "按键 ESC",
                    "pipeline_override": {
                        "Battle_RunEntry": {
                            "action": "ClickKey",
                            "key": 27
                        }
                    }
                }
            ]
        },
        "轮询间隔":{
            "type": "input",
            "inputs": [
                {
                    "name": "polling_interval",
                    "label": "轮询间隔",
                    "default": "2",
                    "pipeline_type": "int",
                    "verify": "^[1-9]$",
                    "pattern_msg": "输入轮询间隔1-9s"
                },
                {
                    "name": "checke_interval",
                    "label": "检测间隔",
                    "default": "500",
                    "pipeline_type": "int",
                    "verify": "^[1-9][0-9]*$",
                    "pattern_msg": "请输入轮询间隔(ms),为正整数,例如500"
                }
            ],
            "pipeline_override": {
                "AutoReleasePet_Entry":{
                    "custom_recognition_param" : "{\"polling_interval\":polling_interval}",
                    "post_delay": "{checke_interval}"
                
                }
            }
        },
        "映射按键": {
            "type": "input",
            "label": "鼠标长按设置",
            "inputs": [
                {
                    "name": "key",
                    "label": "映射按键(字母/数字/空格)",
                    "default": "c",
                    "pipeline_type": "string",
                    "verify": "^[0-9a-zA-Z ]$",
                    "pattern_msg": "请输入一个按键(字母、数字或空格)"
                }
            ],
            "pipeline_override": {
                "MouseLongPressEntry": {
                    "custom_action_param": "{\"key\": key}"
                }
            }
        }
    }    
}