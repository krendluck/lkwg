    {
        // 本文件主要定义了通用 UI 的行为和显示内容
        // 可参考文档和示例添加更多您需要的功能
        // 文档：https://maafw.xyz/docs/3.3-ProjectInterfaceV2
        // 示例：https://github.com/MaaXYZ/MaaFramework/blob/main/sample/interface.json
        "interface_version": 2,
        "name": "MaaLK",
        "description": "这是一个使用 MaaFramework 创建的新项目。",
        "license": "MIT",
        "welcome": "首次使用！欢迎使用 MAA!",
        // 填写项目地址和版本号可实现自动更新功能
        "github": "https://github.com/krendluck/lkwg",
        "version": "0.1.0",
        "controller": [
            {
                "name": "桌面端",
                "type": "Win32",
                "win32": {
                    "class_regex": ".*",
                    "window_regex": "洛克王国：世界",
                    "screencap": "PrintWindow", // 截图方式
                    "mouse": "SendMessageWithCursorPos", // 鼠标控制方式
                    "keyboard": "SendMessageWithCursorPos" // 键盘控制方式
                }
            }
        ],
        "resource": [
            {
                "name": "桌面",
                "path": [
                    "./resource"
                ]
            }
        ],
        // 可选的 agent 示例
        "agent": {
            "child_exec": "python",
            "child_args": [
                "./agent/main.py"
            ]
        },
        "task": [
            {
                "name": "战斗脱离",
                "entry": "Battle_RunEntry"

            },
            {
                "name": "自动聚能",
                "entry": "Focus_EnergyEntry"
            },
            {
                "name": "自动登陆",
                "entry": "Auto_LaunchEntry"
            }
        ]
    }