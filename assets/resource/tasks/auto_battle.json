{
    "task": [
        {
            "name": "自动战斗",
            "entry": "AutoBattle_Entry",
            "option": [
                "战斗类型",
                "使用印记",
                "技能顺序"
            ],
            "group": ["battle"]
        }
    ],
    "option": {
        "战斗类型": {
            "type": "select",
            "default_case": "legendary",
            "cases": [
                {
                    "name": "legendary",
                    "label": "传说精灵"
                },
                {
                    "name": "boss",
                    "label": "精灵首领"
                },
                {
                    "name": "rare",
                    "label": "稀兽花种",
                    "pipeline_override": {
                        "AutoBattle_BattleEndCheck": {
                            "roi": [1230, 673, 14, 11],
                            "expected": ["w"]
                        }
                    }
                }
            ]
        },
        "使用印记": {
            "type": "select",
            "default_case": "不使用",
            "cases": [
                {
                    "name": "不使用",
                    "label": "不使用"
                },
                {
                    "name": "使用",
                    "label": "使用",
                    "pipeline_override": {
                        "AutoBattle_UseMark": {
                            "attach": {
                                "use_mark": "true"
                            }
                        }
                    }
                }
            ]
        },
        "技能顺序": {
            "type": "input",
            "inputs": [
                {
                    "name": "skill_order",
                    "label": "技能顺序 (1-4=技能, x=聚能, q=背包, r=关闭背包, |操作|次数 重复, |操作|a 无限循环)",
                    "default": "|1x|a",
                    "pipeline_type": "string",
                    "verify": "^[1-4xXqQrR|aA0-9]+$",
                    "pattern_msg": "只能包含 1-4, x(聚能), q(背包), r(关闭背包), |操作|次数(重复), |操作|a(无限循环)"
                }
            ],
            "pipeline_override": {
                "AutoBattle_WaitSkill1": {
                    "attach": {
                        "skill_order": "{skill_order}"
                    }
                }
            }
        }
    }
}